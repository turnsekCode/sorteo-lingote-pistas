DirectoryIndex disabled
RewriteEngine On
RewriteRule ^$ http://127.0.0.1:3028/ [P,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ http://127.0.0.1:3028/$1 [P,L]

